# 공공데이터포털(data.go.kr)에서 발급한 서비스키
# TourAPI, 한국수자원공사 물과여행 API 등에 사용
PUBLIC_DATA_SERVICE_KEY=

# OpenWeather API 키 (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# ⚠️ 주의: 실제 키 값은 .env.local 에만 저장하세요.
# .env.local 은 GitHub에 커밋하지 마세요.
# Vercel 배포 시에는 Vercel Dashboard → Settings → Environment Variables 에 등록하세요.
