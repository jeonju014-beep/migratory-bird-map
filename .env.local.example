# 공공데이터포털(data.go.kr)에서 발급한 서비스키
# TourAPI, 울산철새API, odcloud API 등 동일 키 사용 가능
PUBLIC_DATA_SERVICE_KEY=

# OpenWeather API 키 (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# ⚠️ 주의: 실제 키 값은 .env.local 에만 저장하세요.
# GitHub·Vercel Environment Variables에 등록하고 소스코드에는 넣지 마세요.

# 연동 API 예시:
# - 울산광역시 UlsanMigrantAPI (태화강 철새 출현)
# - api.odcloud.kr (제주 도래지, 구미 습지, 전북 습지, 국내 조류분포)
# - KorService2 TourAPI, 물과여행 API
